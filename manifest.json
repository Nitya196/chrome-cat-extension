{
  "manifest_version": 3,
  "name": "Catify",
  "version": "1.0",
  "description": "Replace all images with random cats!",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Catify"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
